@model BG3BuildPlanner.Data.Build

@{
    ViewData["Title"] = "Build Details";
    var characterName = ViewData["CharacterName"] as string ?? "Unknown";
}

<h1>@Model.Title</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Difficulty</dt>
        <dd class="col-sm-10">@Model.Difficulty</dd>

        <dt class="col-sm-2">Character</dt>
        <dd class="col-sm-10">@characterName</dd>

        <dt class="col-sm-2">Created</dt>
        <dd class="col-sm-10">@Model.CreatedAt.ToString("u")</dd>
    </dl>
</div>

<div>
    <h3>Skills</h3>
    <ul>
    @foreach (var skill in Model.Skills)
    {
        <li>@skill.Name (Level @skill.RequiredLevel)</li>
    }
    </ul>
</div>

<div>
    <h3>Items</h3>
    <ul>
    @foreach (var item in Model.Items)
    {
        <li>@item.Name (@item.Type, @item.Rarity, Power @item.Power)</li>
    }
    </ul>
</div>

<div>
    <h3>Ratings</h3>
    <ul>
    @foreach (var rating in Model.Ratings)
    {
        <li>@rating.Score/5 - @rating.Comment</li>
    }
    </ul>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
