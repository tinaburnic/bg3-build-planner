@model IEnumerable<BG3BuildPlanner.Data.Character>

@{
    ViewData["Title"] = "Characters";
}

<h1>Characters</h1>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Race</th>
            <th>Background</th>
            <th>Level</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var character in Model)
    {
        <tr>
            <td>
                <a asp-action="Details" asp-route-id="@character.Id">@character.Name</a>
            </td>
            <td>@character.Race</td>
            <td>@character.Background</td>
            <td>@character.Level</td>
        </tr>
    }
    </tbody>
</table>
