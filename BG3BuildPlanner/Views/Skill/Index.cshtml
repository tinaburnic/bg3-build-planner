@model IEnumerable<BG3BuildPlanner.Data.Skill>

@{
    ViewData["Title"] = "Skills";
}

<h1>Skills</h1>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Required Level</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var skill in Model)
    {
        <tr>
            <td>
                <a asp-action="Details" asp-route-id="@skill.Id">@skill.Name</a>
            </td>
            <td>@skill.RequiredLevel</td>
        </tr>
    }
    </tbody>
</table>
