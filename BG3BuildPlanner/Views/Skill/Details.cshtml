@model BG3BuildPlanner.Data.Skill

@{
    ViewData["Title"] = "Skill Details";
    var skillImage = string.IsNullOrWhiteSpace(Model.ImageUrl)
        ? Url.Content("~/images/skills/Bless.jpg")
        : Url.Content("~" + Model.ImageUrl);
}

<section class="skill-detail-shell reveal-up" aria-label="Skill Detail">
    <span class="frame-corner frame-corner--tl" aria-hidden="true"></span>
    <span class="frame-corner frame-corner--tr" aria-hidden="true"></span>
    <span class="frame-corner frame-corner--bl" aria-hidden="true"></span>
    <span class="frame-corner frame-corner--br" aria-hidden="true"></span>

    <p class="section-label">Skill Profile</p>
    <h1 class="skill-detail-title">@Model.Name</h1>

    <div class="skill-detail-layout">
        <figure class="skill-image-panel">
            <img src="@skillImage" alt="Artwork for @Model.Name" class="skill-detail-image" />
            <figcaption class="skill-image-caption">@Model.Name</figcaption>
        </figure>

        <article class="skill-detail-card" aria-label="Skill Information">
            <header class="skill-detail-card-header">
                <p class="section-label mb-1">Overview</p>
                <h2>@Model.Name</h2>
            </header>

            <dl class="skill-detail-table">
                <div class="skill-detail-row">
                    <dt>Description</dt>
                    <dd>@Model.Description</dd>
                </div>
                <div class="skill-detail-row">
                    <dt>Required Level</dt>
                    <dd>@Model.RequiredLevel</dd>
                </div>
            </dl>

            <a asp-action="Index" class="btn btn-outline-gold skill-detail-back">Back to Skills</a>
        </article>
    </div>
</section>

